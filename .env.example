# Configuración de la base de datos
# Para desarrollo con SQLite (recomendado):
DATABASE_URL=sqlite:///./bank_app.db

# Para producción con MySQL:
# DATABASE_URL=mysql+pymysql://usuario:contraseña@host:puerto/nombre_base_datos

# Para PostgreSQL:
# DATABASE_URL=postgresql://usuario:contraseña@host:puerto/nombre_base_datos

# Ejemplos:
# DATABASE_URL=mysql+pymysql://root:password123@localhost:3306/bank_app
# DATABASE_URL=postgresql://user:pass123@db.example.com:5432/bank_app